# PostgreSQL connection string. For production, set your own.
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/cgr_shop"

# Default admin credentials, used by the seed script to create the first admin user.
ADMIN_EMAIL="admin@cashesgreen.ru"
ADMIN_PASSWORD="change-me"

# Secret used to sign the admin session cookie.
# ОБЯЗАТЕЛЬНО: задайте случайную строку длиной не менее 32 символов (32+ байта).
# Сгенерируйте, например: `openssl rand -hex 32`. Без валидного значения приложение
# откажется подписывать/проверять сессии (fail-fast). НЕ используйте это значение как есть.
AUTH_SECRET="CHANGE-ME-run-openssl-rand-hex-32-to-generate"

# Public base URL of the site (used for canonical URLs, sitemap, OG images).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
